# Supabase — find these in your project settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GitHub — create a Personal Access Token at github.com/settings/tokens
# Scopes needed: repo (full control of private repos) or just public_repo for public repos
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=mmcintyre1
GITHUB_REPO=silently-failing
GITHUB_BRANCH=master
