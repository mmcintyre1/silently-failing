# Admin credentials — set these in Netlify environment variables
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=choose-a-strong-password

# Session signing secret — generate with: openssl rand -hex 32
AUTH_SECRET=replace-with-random-hex-string

# GitHub — create a Personal Access Token at github.com/settings/tokens
# Scopes needed: Contents (read/write) under "Repository permissions" (fine-grained token)
# or "repo" scope for a classic token
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=mmcintyre1
GITHUB_REPO=silently-failing
GITHUB_BRANCH=master
