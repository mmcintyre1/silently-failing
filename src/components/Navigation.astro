---
const { pathname } = Astro.url

function isActive(path: string) {
  if (path === '/blog') return pathname.startsWith('/blog') || pathname.startsWith('/tags')
  return pathname.startsWith(path)
}
---

<header class="border-b border-stone-100">
  <nav class="flex items-center justify-between py-4 px-4 max-w-[65ch] mx-auto">
    <a
      href="/"
      class="font-medium text-stone-900 hover:text-teal-700 transition-colors duration-150"
    >
      silently failing
    </a>
    <div class="flex items-center gap-5">
      {[
        { href: '/blog', label: 'blog' },
        { href: '/projects', label: 'projects' },
        { href: '/about', label: 'about' },
      ].map(({ href, label }) => (
        <a
          href={href}
          class={`text-sm transition-colors duration-150 ${
            isActive(href)
              ? 'text-teal-700'
              : 'text-stone-500 hover:text-stone-900'
          }`}
        >
          {label}
        </a>
      ))}
    </div>
  </nav>
</header>
