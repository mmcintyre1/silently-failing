---
import BaseLayout from '../layouts/BaseLayout.astro'
import projectsData from '../data/projects.json'

interface Project {
  name: string
  description: string
  url: string
  tags: string[]
  status: 'active' | 'in-progress' | 'archived'
}

const projects = projectsData as Project[]

const statusLabel: Record<Project['status'], string> = {
  active: 'Active',
  'in-progress': 'In progress',
  archived: 'Archived',
}

const statusColor: Record<Project['status'], string> = {
  active: 'text-teal-700 bg-teal-50',
  'in-progress': 'text-amber-700 bg-amber-50',
  archived: 'text-stone-500 bg-stone-100',
}
---

<BaseLayout
  title="Projects — Silently Failing"
  description="Things I've built."
>
  <div class="py-12">
    <h1 class="text-xl font-semibold text-stone-900">Projects</h1>
    <p class="mt-2 text-stone-500 leading-relaxed">
      Things I've built. Each one lives at its own deploy.
    </p>

    {projects.length === 0 ? (
      <p class="mt-10 text-sm text-stone-400">Nothing here yet — check back soon.</p>
    ) : (
      <div class="mt-8 flex flex-col gap-6">
        {projects.map((project) => (
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group block border border-stone-100 rounded-lg p-5 hover:border-stone-200 transition-colors duration-150"
          >
            <div class="flex items-start justify-between gap-4">
              <h2 class="font-medium text-stone-900 group-hover:text-teal-700 transition-colors duration-150">
                {project.name}
              </h2>
              <span class={`text-xs px-2 py-0.5 rounded shrink-0 ${statusColor[project.status]}`}>
                {statusLabel[project.status]}
              </span>
            </div>
            <p class="mt-1.5 text-sm text-stone-500 leading-relaxed">
              {project.description}
            </p>
            {project.tags.length > 0 && (
              <div class="flex gap-2 mt-3 flex-wrap">
                {project.tags.map((tag) => (
                  <span class="text-xs text-stone-400">#{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
