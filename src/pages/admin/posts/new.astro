---
export const prerender = false

import AdminLayout from '../../../layouts/AdminLayout.astro'
import { getSupabase } from '../../../lib/supabase'

let errorMessage = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const title = form.get('title')?.toString() ?? ''
  const slug = form.get('slug')?.toString().trim() ?? ''
  const description = form.get('description')?.toString() ?? ''
  const tagsRaw = form.get('tags')?.toString() ?? ''
  const content = form.get('content')?.toString() ?? ''
  const tags = tagsRaw
    .split(',')
    .map((t) => t.trim())
    .filter(Boolean)

  if (!slug) {
    errorMessage = 'Slug is required.'
  } else {
    const db = getSupabase()
    const { data, error } = await db
      .from('posts')
      .insert({ title, slug, description, content, tags, draft: true })
      .select('id')
      .single()

    if (error) {
      errorMessage = error.message
    } else {
      return Astro.redirect(`/admin/posts/${data.id}?saved=1`)
    }
  }
}
---

<AdminLayout title="New Post">
  <div class="flex items-center gap-3 mb-6">
    <a href="/admin/posts" class="text-sm text-stone-400 hover:text-stone-700">← Posts</a>
    <h1 class="text-lg font-semibold text-stone-900">New post</h1>
  </div>

  {errorMessage && (
    <div class="mb-4 text-sm text-red-600 bg-red-50 border border-red-200 rounded px-3 py-2">
      {errorMessage}
    </div>
  )}

  <form method="POST" id="post-form" class="flex flex-col gap-4">
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label for="title" class="block text-xs font-medium text-stone-600 mb-1">Title</label>
        <input
          type="text"
          id="title"
          name="title"
          autofocus
          class="w-full border border-stone-200 rounded px-3 py-2 text-sm focus:outline-none focus:border-teal-500 bg-white"
        />
      </div>
      <div>
        <label for="slug" class="block text-xs font-medium text-stone-600 mb-1">
          Slug <span class="text-stone-400 font-normal">(URL path, e.g. my-post)</span>
        </label>
        <input
          type="text"
          id="slug"
          name="slug"
          pattern="[a-z0-9-]+"
          class="w-full border border-stone-200 rounded px-3 py-2 text-sm focus:outline-none focus:border-teal-500 bg-white font-mono"
        />
      </div>
    </div>

    <div>
      <label for="description" class="block text-xs font-medium text-stone-600 mb-1">
        Description <span class="text-stone-400 font-normal">(optional — shown in post list)</span>
      </label>
      <input
        type="text"
        id="description"
        name="description"
        class="w-full border border-stone-200 rounded px-3 py-2 text-sm focus:outline-none focus:border-teal-500 bg-white"
      />
    </div>

    <div>
      <label for="tags" class="block text-xs font-medium text-stone-600 mb-1">
        Tags <span class="text-stone-400 font-normal">(comma-separated)</span>
      </label>
      <input
        type="text"
        id="tags"
        name="tags"
        placeholder="books, tech, life"
        class="w-full border border-stone-200 rounded px-3 py-2 text-sm focus:outline-none focus:border-teal-500 bg-white"
      />
    </div>

    <!-- Split-pane editor -->
    <div>
      <label class="block text-xs font-medium text-stone-600 mb-1">Content</label>
      <div class="flex gap-3 h-[60vh] min-h-[400px]">
        <textarea
          id="editor"
          name="content"
          class="flex-1 font-mono text-sm p-4 border border-stone-200 rounded-lg resize-none focus:outline-none focus:border-teal-500 bg-white leading-relaxed"
          placeholder="Write your post in markdown..."
        ></textarea>
        <div
          id="preview"
          class="flex-1 prose max-w-none p-4 border border-stone-100 rounded-lg overflow-y-auto bg-white text-sm"
        >
          <p class="text-stone-300 italic text-sm">Preview will appear here…</p>
        </div>
      </div>
    </div>

    <div class="flex justify-end gap-3 pt-2">
      <button
        type="submit"
        class="text-sm bg-stone-800 text-white font-medium rounded px-4 py-2 hover:bg-stone-900 transition-colors"
      >
        Save draft
      </button>
    </div>
  </form>

  <!-- Auto-generate slug from title -->
  <script>
    const titleInput = document.getElementById('title') as HTMLInputElement
    const slugInput = document.getElementById('slug') as HTMLInputElement
    let slugTouched = false

    slugInput.addEventListener('input', () => {
      slugTouched = true
    })

    titleInput.addEventListener('input', () => {
      if (!slugTouched) {
        slugInput.value = titleInput.value
          .toLowerCase()
          .replace(/[^a-z0-9\s-]/g, '')
          .trim()
          .replace(/\s+/g, '-')
      }
    })
  </script>

  <!-- Split-pane markdown preview -->
  <script>
    import { marked } from 'marked'

    const editor = document.getElementById('editor') as HTMLTextAreaElement
    const preview = document.getElementById('preview') as HTMLDivElement

    async function updatePreview() {
      const html = await marked.parse(editor.value)
      preview.innerHTML = html || '<p class="text-stone-300 italic text-sm">Preview will appear here…</p>'
    }

    editor.addEventListener('input', updatePreview)
  </script>
</AdminLayout>
