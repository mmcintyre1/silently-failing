---
export const prerender = false

import AdminLayout from '../../../layouts/AdminLayout.astro'
import { listFiles, getFile, parsePostFrontmatter } from '../../../lib/github'

const files = await listFiles('src/content/posts')

// Fetch each post's frontmatter in parallel
const posts = (
  await Promise.all(
    files.map(async ({ name }) => {
      const file = await getFile(`src/content/posts/${name}`)
      if (!file) return null
      const { title, date, draft } = parsePostFrontmatter(file.content)
      return {
        slug: name.replace(/\.md$/, ''),
        title: title || name.replace(/\.md$/, ''),
        date,
        draft,
      }
    }),
  )
)
  .filter(Boolean)
  .sort((a, b) => (b!.date > a!.date ? 1 : -1))
---

<AdminLayout title="Posts">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-lg font-semibold text-stone-900">Posts</h1>
    <a
      href="/admin/posts/new"
      class="text-sm bg-teal-700 text-white font-medium rounded px-3 py-1.5 hover:bg-teal-800 transition-colors"
    >
      + New post
    </a>
  </div>

  {posts.length === 0 ? (
    <p class="text-sm text-stone-400 mt-8">No posts yet. Create one above.</p>
  ) : (
    <div class="bg-white border border-stone-200 rounded-lg divide-y divide-stone-100">
      {posts.map((post) => (
        <div class="flex items-center justify-between px-4 py-3 gap-4">
          <div class="min-w-0">
            <a
              href={`/admin/posts/${post!.slug}`}
              class="text-sm font-medium text-stone-900 hover:text-teal-700 transition-colors truncate block"
            >
              {post!.title}
            </a>
            <p class="text-xs text-stone-400 mt-0.5">
              /{post!.slug}
              {post!.date && ` · ${post!.date}`}
            </p>
          </div>
          <span
            class={`text-xs px-2 py-0.5 rounded shrink-0 ${
              post!.draft ? 'text-amber-700 bg-amber-50' : 'text-teal-700 bg-teal-50'
            }`}
          >
            {post!.draft ? 'Draft' : 'Published'}
          </span>
        </div>
      ))}
    </div>
  )}
</AdminLayout>
