---
export const prerender = false

import AdminLayout from '../../../layouts/AdminLayout.astro'
import { getFile, putFile, buildPostMarkdown, parsePostFrontmatter } from '../../../lib/github'

const { slug } = Astro.params
if (!slug) return Astro.redirect('/admin/posts')

const filePath = `src/content/posts/${slug}.md`
let errorMessage = ''
let successMessage = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const title = form.get('title')?.toString() ?? ''
  const description = form.get('description')?.toString() ?? ''
  const tagsRaw = form.get('tags')?.toString() ?? ''
  const content = form.get('content')?.toString() ?? ''
  const date = form.get('date')?.toString() ?? ''
  const sha = form.get('sha')?.toString()
  const action = form.get('action')?.toString() ?? 'draft'
  const isDraft = action !== 'publish'

  const tags = tagsRaw
    .split(',')
    .map((t) => t.trim())
    .filter(Boolean)

  const markdown = buildPostMarkdown({ title, description, content, tags, draft: isDraft, date })

  try {
    await putFile(
      filePath,
      markdown,
      isDraft ? `Update draft: ${title || slug}` : `Publish post: ${title || slug}`,
      sha,
    )
    successMessage = isDraft ? 'Draft saved.' : 'Published! Netlify will rebuild in ~30 seconds.'
  } catch (err) {
    errorMessage = err instanceof Error ? err.message : 'Unknown error'
  }
}

// Always reload from GitHub so the form reflects latest state (and gets fresh SHA)
const file = await getFile(filePath)
if (!file) return Astro.redirect('/admin/posts')

const post = parsePostFrontmatter(file.content)
const tagsJoined = post.tags.join(', ')
const savedParam = Astro.url.searchParams.get('saved') === '1'
---

<AdminLayout title={post.title || slug}>
  <div class="flex items-center gap-3 mb-6">
    <a href="/admin/posts" class="text-sm text-stone-400 hover:text-stone-700">← Posts</a>
    <h1 class="text-lg font-semibold text-stone-900 truncate">
      {post.title || <span class="text-stone-400 italic">Untitled</span>}
    </h1>
    <span class={`text-xs px-2 py-0.5 rounded shrink-0 ${post.draft ? 'text-amber-700 bg-amber-50' : 'text-teal-700 bg-teal-50'}`}>
      {post.draft ? 'Draft' : 'Published'}
    </span>
  </div>

  {(savedParam || successMessage) && (
    <div class="mb-4 text-sm text-teal-700 bg-teal-50 border border-teal-200 rounded px-3 py-2">
      {successMessage || 'Saved.'}
    </div>
  )}
  {errorMessage && (
    <div class="mb-4 text-sm text-red-600 bg-red-50 border border-red-200 rounded px-3 py-2">
      {errorMessage}
    </div>
  )}

  <form method="POST" class="flex flex-col gap-4">
    <!-- Hidden fields passed through the form -->
    <input type="hidden" name="sha" value={file.sha} />
    <input type="hidden" name="date" value={post.date} />

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label for="title" class="block text-xs font-medium text-stone-600 mb-1">Title</label>
        <input
          type="text"
          id="title"
          name="title"
          value={post.title}
          class="w-full border border-stone-200 rounded px-3 py-2 text-sm focus:outline-none focus:border-teal-500 bg-white"
        />
      </div>
      <div>
        <label class="block text-xs font-medium text-stone-600 mb-1">
          Slug <span class="text-stone-400 font-normal">(filename — change requires renaming the file in GitHub)</span>
        </label>
        <input
          type="text"
          value={slug}
          disabled
          class="w-full border border-stone-100 rounded px-3 py-2 text-sm bg-stone-50 text-stone-400 font-mono cursor-not-allowed"
        />
      </div>
    </div>

    <div>
      <label for="description" class="block text-xs font-medium text-stone-600 mb-1">
        Description
      </label>
      <input
        type="text"
        id="description"
        name="description"
        value={post.description}
        class="w-full border border-stone-200 rounded px-3 py-2 text-sm focus:outline-none focus:border-teal-500 bg-white"
      />
    </div>

    <div>
      <label for="tags" class="block text-xs font-medium text-stone-600 mb-1">
        Tags <span class="text-stone-400 font-normal">(comma-separated)</span>
      </label>
      <input
        type="text"
        id="tags"
        name="tags"
        value={tagsJoined}
        class="w-full border border-stone-200 rounded px-3 py-2 text-sm focus:outline-none focus:border-teal-500 bg-white"
      />
    </div>

    <div>
      <label class="block text-xs font-medium text-stone-600 mb-1">Content</label>
      <div class="flex gap-3 h-[60vh] min-h-[400px]">
        <textarea
          id="editor"
          name="content"
          class="flex-1 font-mono text-sm p-4 border border-stone-200 rounded-lg resize-none focus:outline-none focus:border-teal-500 bg-white leading-relaxed"
        >{post.body}</textarea>
        <div
          id="preview"
          class="flex-1 prose max-w-none p-4 border border-stone-100 rounded-lg overflow-y-auto bg-white text-sm"
        ></div>
      </div>
    </div>

    <div class="flex justify-between items-center pt-2">
      <div class="text-xs text-stone-400">
        {post.date && `Date: ${post.date} · `}/<span class="font-mono">{slug}</span>
        {!post.draft && (
          <a
            href={`/blog/${slug}`}
            target="_blank"
            class="ml-2 text-teal-600 hover:text-teal-800"
          >
            view post ↗
          </a>
        )}
      </div>
      <div class="flex gap-3">
        <button
          type="submit"
          name="action"
          value="draft"
          class="text-sm bg-stone-800 text-white font-medium rounded px-4 py-2 hover:bg-stone-900 transition-colors"
        >
          Save draft
        </button>
        <button
          type="submit"
          name="action"
          value="publish"
          class="text-sm bg-teal-700 text-white font-medium rounded px-4 py-2 hover:bg-teal-800 transition-colors"
        >
          {post.draft ? 'Publish' : 'Republish'}
        </button>
      </div>
    </div>
  </form>

  <script>
    import { marked } from 'marked'
    const editor = document.getElementById('editor') as HTMLTextAreaElement
    const preview = document.getElementById('preview') as HTMLDivElement

    async function updatePreview() {
      preview.innerHTML = await marked.parse(editor.value)
    }

    editor.addEventListener('input', updatePreview)
    updatePreview()
  </script>
</AdminLayout>
