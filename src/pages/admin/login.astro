---
export const prerender = false

import { checkCredentials, createSessionToken } from '../../lib/auth'
import '../../styles/global.css'

let errorMessage = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const email = form.get('email')?.toString() ?? ''
  const password = form.get('password')?.toString() ?? ''

  if (checkCredentials(email, password)) {
    const token = await createSessionToken()
    Astro.cookies.set('admin-token', token, {
      httpOnly: true,
      secure: import.meta.env.PROD,
      sameSite: 'strict',
      maxAge: 60 * 60 * 24 * 7,
      path: '/',
    })
    return Astro.redirect('/admin/posts')
  }

  errorMessage = 'Invalid credentials.'
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login — Admin</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-stone-50 text-stone-900 font-sans min-h-screen flex items-center justify-center">
    <div class="w-full max-w-sm px-6">
      <h1 class="text-lg font-semibold text-stone-900 mb-1">Admin</h1>
      <p class="text-sm text-stone-500 mb-8">silentlyfailing.com</p>

      {errorMessage && (
        <div class="mb-4 text-sm text-red-600 bg-red-50 border border-red-200 rounded px-3 py-2">
          {errorMessage}
        </div>
      )}

      <form method="POST" class="flex flex-col gap-4">
        <div>
          <label for="email" class="block text-xs font-medium text-stone-600 mb-1">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autofocus
            class="w-full border border-stone-200 rounded px-3 py-2 text-sm focus:outline-none focus:border-teal-500 bg-white"
          />
        </div>

        <div>
          <label for="password" class="block text-xs font-medium text-stone-600 mb-1">
            Password
          </label>
          <input
            type="password"
            id="password"
            name="password"
            required
            class="w-full border border-stone-200 rounded px-3 py-2 text-sm focus:outline-none focus:border-teal-500 bg-white"
          />
        </div>

        <button
          type="submit"
          class="mt-2 bg-teal-700 text-white text-sm font-medium rounded px-4 py-2 hover:bg-teal-800 transition-colors"
        >
          Sign in
        </button>
      </form>
    </div>
  </body>
</html>
