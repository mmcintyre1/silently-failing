---
export const prerender = false

import AdminLayout from '../../layouts/AdminLayout.astro'
import { getFile, putFile } from '../../lib/github'

let errorMessage = ''
let successMessage = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const content = form.get('content')?.toString() ?? ''

  try {
    const file = await getFile('src/data/about.md')
    await putFile(
      'src/data/about.md',
      content,
      'Update about page via admin',
      file?.sha,
    )
    successMessage = 'Saved and committed. Netlify will rebuild in ~30 seconds.'
  } catch (err) {
    errorMessage = err instanceof Error ? err.message : 'Unknown error'
  }
}

// Load current about content from GitHub
const file = await getFile('src/data/about.md')
const currentContent = file?.content ?? ''
---

<AdminLayout title="About">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-lg font-semibold text-stone-900">About</h1>
    <p class="text-xs text-stone-400">Changes commit directly to GitHub and trigger a Netlify rebuild.</p>
  </div>

  {successMessage && (
    <div class="mb-4 text-sm text-teal-700 bg-teal-50 border border-teal-200 rounded px-3 py-2">
      {successMessage}
    </div>
  )}
  {errorMessage && (
    <div class="mb-4 text-sm text-red-600 bg-red-50 border border-red-200 rounded px-3 py-2">
      {errorMessage}
    </div>
  )}

  <form method="POST" class="flex flex-col gap-4">
    <div>
      <label class="block text-xs font-medium text-stone-600 mb-1">
        Content <span class="text-stone-400 font-normal">(Markdown)</span>
      </label>
      <div class="flex gap-3 h-[60vh] min-h-[400px]">
        <textarea
          id="editor"
          name="content"
          class="flex-1 font-mono text-sm p-4 border border-stone-200 rounded-lg resize-none focus:outline-none focus:border-teal-500 bg-white leading-relaxed"
        >{currentContent}</textarea>
        <div
          id="preview"
          class="flex-1 prose max-w-none p-4 border border-stone-100 rounded-lg overflow-y-auto bg-white text-sm"
        ></div>
      </div>
    </div>

    <div class="flex justify-end pt-2">
      <button
        type="submit"
        class="text-sm bg-teal-700 text-white font-medium rounded px-4 py-2 hover:bg-teal-800 transition-colors"
      >
        Save &amp; publish
      </button>
    </div>
  </form>

  <script>
    import { marked } from 'marked'

    const editor = document.getElementById('editor') as HTMLTextAreaElement
    const preview = document.getElementById('preview') as HTMLDivElement

    async function updatePreview() {
      preview.innerHTML = await marked.parse(editor.value)
    }

    editor.addEventListener('input', updatePreview)
    updatePreview()
  </script>
</AdminLayout>
