---
import BaseLayout from '../layouts/BaseLayout.astro'
import { marked } from 'marked'
import aboutContent from '../data/about.md?raw'

const aboutHtml = await marked.parse(aboutContent)
---

<BaseLayout
  title="About — Silently Failing"
  description="A bit about Michael McIntyre."
>
  <div class="py-12">
    <h1 class="text-xl font-semibold text-stone-900">About</h1>

    <div class="prose max-w-none mt-8" set:html={aboutHtml} />
  </div>
</BaseLayout>
