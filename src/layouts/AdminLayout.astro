---
import '../styles/global.css'

interface Props {
  title: string
}

const { title } = Astro.props
const pathname = Astro.url.pathname

const navLinks = [
  { href: '/admin/posts', label: 'Posts' },
  { href: '/admin/projects', label: 'Projects' },
  { href: '/admin/about', label: 'About' },
]
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Admin</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-stone-50 text-stone-900 font-sans min-h-screen">
    <header class="border-b border-stone-200 bg-white sticky top-0 z-10">
      <div class="max-w-5xl mx-auto px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-6">
          <span class="text-sm text-stone-400 font-medium">
            silently failing <span class="text-stone-300 font-normal">/</span> admin
          </span>
          <nav class="flex gap-5">
            {navLinks.map(({ href, label }) => (
              <a
                href={href}
                class={`text-sm transition-colors duration-150 ${
                  pathname.startsWith(href)
                    ? 'text-teal-700 font-medium'
                    : 'text-stone-500 hover:text-stone-900'
                }`}
              >
                {label}
              </a>
            ))}
          </nav>
        </div>
        <div class="flex items-center gap-5">
          <a
            href="/"
            target="_blank"
            class="text-xs text-stone-400 hover:text-stone-600 transition-colors"
          >
            view site ↗
          </a>
          <form method="POST" action="/api/auth/logout">
            <button
              type="submit"
              class="text-xs text-stone-400 hover:text-stone-600 transition-colors"
            >
              logout
            </button>
          </form>
        </div>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-6 py-8">
      <slot />
    </main>
  </body>
</html>
