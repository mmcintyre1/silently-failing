---
import BaseLayout from './BaseLayout.astro'
import TagBadge from '../components/TagBadge.astro'

interface Props {
  title: string
  date: Date
  description?: string
  tags: string[]
  lastUpdated?: Date
}

const { title, date, description, tags, lastUpdated } = Astro.props

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

const formattedLastUpdated = lastUpdated?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<BaseLayout
  title={`${title} — Silently Failing`}
  description={description}
  ogType="article"
>
  <article class="py-12">
    <header class="mb-10">
      <h1 class="text-2xl font-semibold text-stone-900 leading-snug">{title}</h1>
      {description && (
        <p class="mt-2 text-stone-500 leading-relaxed">{description}</p>
      )}
      <div class="flex items-center gap-2.5 mt-4 flex-wrap">
        <time class="text-sm text-stone-400" datetime={date.toISOString()}>
          {formattedDate}
        </time>
        {lastUpdated && (
          <span class="text-sm text-stone-400">· updated {formattedLastUpdated}</span>
        )}
        {tags.map((tag) => <TagBadge tag={tag} />)}
      </div>
    </header>
    <div class="prose max-w-none">
      <slot />
    </div>
    <div class="mt-12 pt-6 border-t border-stone-100">
      <a href="/blog" class="text-sm text-teal-700 hover:text-teal-600 transition-colors duration-150">
        ← All posts
      </a>
    </div>
  </article>
</BaseLayout>
